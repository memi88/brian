generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Paciente {
  id              String    @id @default(cuid())
  nome            String
  dataNascimento  DateTime?
  responsavel     String?
  contato         String?
  dataInicioAcomp DateTime?
  observacoes     String?
  ativo           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  atendimentos Atendimento[]
  tarefas      Tarefa[]
  planos       PlanoSessao[]
  avaliacoes   Avaliacao[]
}

model Atendimento {
  id         String   @id @default(cuid())
  pacienteId String
  data       DateTime
  horario    String?
  resumo     String?
  atividades String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paciente Paciente      @relation(fields: [pacienteId], references: [id])
  tarefas  Tarefa[]
  plano    PlanoSessao?
}

model Tarefa {
  id            String       @id @default(cuid())
  pacienteId    String
  atendimentoId String?
  descricao     String
  status        StatusTarefa @default(PENDENTE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  paciente    Paciente     @relation(fields: [pacienteId], references: [id])
  atendimento Atendimento? @relation(fields: [atendimentoId], references: [id])
}

enum StatusTarefa {
  PENDENTE
  CONCLUIDA
}

// Plano criado antes de um atendimento. Mostra tarefas pendentes do último atendimento.
// Vinculado ao atendimento após ele ser registrado (atendimentoId fica nulo até lá).
model PlanoSessao {
  id            String   @id @default(cuid())
  pacienteId    String
  plano         String
  atendimentoId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  paciente    Paciente     @relation(fields: [pacienteId], references: [id])
  atendimento Atendimento? @relation(fields: [atendimentoId], references: [id])
}

model CategoriaSemantica {
  id        String   @id @default(cuid())
  nome      String
  cor       String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  avaliacoes Avaliacao[]
}

model Avaliacao {
  id               String   @id @default(cuid())
  pacienteId       String
  categoriaId      String
  dataAplicacao    DateTime @default(now())
  duracaoSegundos  Int?
  totalPalavras    Int      @default(0)
  totalValidas     Int      @default(0)
  totalRepeticoes  Int      @default(0)
  totalIntrusoes   Int      @default(0)
  totalNeologismos Int      @default(0)
  transcricaoRaw   String?
  revisaoCompleta  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  paciente  Paciente           @relation(fields: [pacienteId], references: [id])
  categoria CategoriaSemantica @relation(fields: [categoriaId], references: [id])
  palavras  Palavra[]
}

model Palavra {
  id          String      @id @default(cuid())
  avaliacaoId String
  texto       String
  timestamp   Float
  bloco       Int
  tipo        TipoPalavra @default(VALIDA)

  avaliacao Avaliacao @relation(fields: [avaliacaoId], references: [id])
}

enum TipoPalavra {
  VALIDA
  REPETICAO
  INTRUSAO
  NEOLOGISMO
}
